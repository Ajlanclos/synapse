# Copy this to .env.local and fill in your keys

# Anthropic - console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Stripe - dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_webhook_secret_here
STRIPE_PRICE_ID=your_stripe_price_id_here

# Your deployed URL
NEXT_PUBLIC_URL=http://localhost:3000

# NextAuth - generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth - console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Supabase - supabase.com/dashboard/project/yefizvkaqcrhffxztmoa/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://yefizvkaqcrhffxztmoa.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Discord OAuth - discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
