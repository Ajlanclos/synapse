# Copy this to .env.local and fill in your keys
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Get from: dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Get from: dashboard.stripe.com/webhooks (after deploying)
STRIPE_WEBHOOK_SECRET=your_webhook_secret_here

# Your Vercel deployment URL (update after deploying)
NEXT_PUBLIC_URL=http://localhost:3000

# Price ID from Stripe dashboard (create a product at $9.99/mo)
STRIPE_PRICE_ID=your_stripe_price_id_here
